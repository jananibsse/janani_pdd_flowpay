Test_Results/
Appium_Results/
Performance_Results/
automation/selenium/reports/
automation/selenium/screenshots/
automation/selenium/logs/
automation/appium/test-output/
automation/appium/surefire-reports/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Node (k6/Artillery)
node_modules/

# Logs
*.log
logs/

# Temp
*.tmp
*.bak
*.orig
